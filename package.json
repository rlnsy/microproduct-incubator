{
  "name": "microproduct-incubator",
  "version": "0.1.0",
  "private": true,
  "description": "Microproduct Incubator Open Knowledge Hub",
  "scripts": {
    "dev": "docusaurus start",
    "start": "npm run dev",
    "build": "docusaurus build",
    "serve": "docusaurus serve",
    "clear": "docusaurus clear",
    "clean": "docusaurus clear && rm -rf build coverage",
    "validate:frontmatter": "node scripts/validate-frontmatter.mjs",
    "lint:markdown": "markdownlint \"docs/**/*.md\" \"README.md\" \"CONTRIBUTING.md\" \"CODE_OF_CONDUCT.md\" \"templates/**/*.md\"",
    "check": "npm run validate:frontmatter && npm run lint:markdown && npm run build",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@docusaurus/core": "^3.9.2",
    "@docusaurus/preset-classic": "^3.9.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^3.9.2",
    "@docusaurus/tsconfig": "^3.9.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.14.10",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "markdownlint-cli": "^0.48.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.5.4"
  },
  "overrides": {
    "serialize-javascript": "^7.0.0",
    "@tootallnate/once": "^3.0.1"
  },
  "engines": {
    "node": ">=20.0"
  }
}

{
  "name": "microproduct-lab",
  "version": "0.1.0",
  "private": true,
  "description": "Build Trilemma — open knowledge hub for microproducts (Docusaurus)",
  "scripts": {
    "predev": "node scripts/clear-dev-cache.mjs",
    "dev": "docusaurus start",
    "start": "npm run dev",
    "build": "node scripts/generate-llms-full.mjs && docusaurus build",
    "serve": "docusaurus serve",
    "clear": "docusaurus clear",
    "clean": "docusaurus clear && rm -rf build coverage",
    "validate:frontmatter": "node scripts/validate-frontmatter.mjs",
    "validate:registry": "node scripts/validate-registry.mjs",
    "lint:markdown": "markdownlint \"docs/**/*.md\" \"docs/**/*.mdx\" \"README.md\" \"CONTRIBUTING.md\" \"CODE_OF_CONDUCT.md\" \"templates/**/*.md\" \"product-templates/**/*.md\" \"products/**/*.md\"",
    "spellcheck": "cspell \"docs/**\" \"product-templates/**\" \"templates/**/*.md\"",
    "check": "npm run spellcheck && npm run validate:frontmatter && npm run validate:registry && npm run lint:markdown && npm run build",
    "test": "jest && node --test scripts/__tests__/llmsMdxUtils.test.mjs",
    "test:coverage": "jest --coverage && node --test scripts/__tests__/llmsMdxUtils.test.mjs"
  },
  "dependencies": {
    "@docusaurus/core": "^3.10.1",
    "@docusaurus/preset-classic": "^3.10.1",
    "clsx": "^2.1.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^3.10.1",
    "@docusaurus/tsconfig": "^3.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.39",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "cspell": "^10.0.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "markdownlint-cli": "^0.48.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "serialize-javascript": "^7.0.0",
    "@tootallnate/once": "^3.0.1"
  },
  "engines": {
    "node": ">=22.18.0"
  }
}
